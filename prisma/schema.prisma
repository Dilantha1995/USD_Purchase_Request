generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  USER
}

enum RequestStatus {
  PENDING
  PAID
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(USER)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  requests     Request[]
}

model Company {
  id          String    @id // "PSMS" or "PPM"
  name        String // full legal name shown on the document title
  refPrefix   String // e.g. "PSMS" -> ref becomes PSMS/DEX/YYMM/NN
  brandColor  String // hex used in the UI
  templatePdf Bytes // the company letterhead PDF, overlaid at generation time
  nextSerial  Int       @default(1) // continuous counter; never resets
  requests    Request[]
}

model Request {
  id            String        @id @default(cuid())
  refNo         String        @unique
  serial        Int
  company       Company       @relation(fields: [companyId], references: [id])
  companyId     String
  date          DateTime // document date, drives the YYMM in the ref no
  usdAmount     Float
  rate          Float
  source        String // where the USD is bought from, e.g. "Island amenities"
  sourceAccount String // e.g. "PSMS BML MVR"
  requestedBy   String
  approvedBy    String
  transfers     Json // [{ recipient, account, amounts: number[] }]
  status        RequestStatus @default(PENDING)
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdById   String
  createdAt     DateTime      @default(now())

  @@index([companyId])
  @@index([createdById])
}
