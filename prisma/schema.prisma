generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  ADMIN
  USER
}

enum RequestStatus {
  PENDING
  PAID
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(USER)
  active       Boolean  @default(true)

  canEditRequests       Boolean @default(false)
  canDeleteRequests     Boolean @default(false)
  canManageSuppliers    Boolean @default(false)
  canManageBankAccounts Boolean @default(false)

  createdAt    DateTime  @default(now())
  requests     Request[]
}

model Company {
  id           String        @id
  name         String
  refPrefix    String
  brandColor   String
  templatePdf  Bytes
  nextSerial   Int           @default(1)
  requests     Request[]
  bankAccounts BankAccount[]
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  bankName    String?
  accountName String?
  accountNo   String?
  notes       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model BankAccount {
  id          String   @id @default(cuid())
  company     Company? @relation(fields: [companyId], references: [id])
  companyId   String?
  label       String
  bankName    String?
  accountName String?
  accountNo   String?
  currency    String   @default("MVR")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Signatory {
  id        String   @id @default(cuid())
  name      String
  title     String?
  kind      String   @default("BOTH")
  signature Bytes?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Request {
  id            String        @id @default(cuid())
  refNo         String        @unique
  serial        Int
  company       Company       @relation(fields: [companyId], references: [id])
  companyId     String
  date          DateTime
  usdAmount     Float
  rate          Float
  source        String
  sourceAccount String
  requestedBy   String
  approvedBy    String
  transfers     Json

  status        RequestStatus @default(PENDING)

  requestedSignatoryId String?
  approvedSignatoryId  String?

  receipts    Json?
  completedAt DateTime?

  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([createdById])
}
